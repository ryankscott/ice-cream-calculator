{
  "name": "ice-cream-calculator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run --passWithNoTests",
    "openapi:lint": "pnpm exec spectral lint schema/ingredients.yaml",
    "openapi:generate": "node scripts/generate-from-openapi.mjs",
    "server:start": "pnpm exec tsx src/server/server.ts",
    "db:migrate": "pnpm exec tsx scripts/run-migrations.ts",
    "db:revert": "pnpm exec tsx scripts/revert-migration.ts",
    "db:generate": "pnpm exec typeorm-ts-node-esm migration:generate src/server/migrations/auto --dataSource src/server/data-source.ts",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^6.0.0",
