    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^2.0.16",
    "@vitejs/plugin-react": "^5.0.4",
    "fs-extra": "^11.2.0",
    "jsdom": "^27.0.0",
    "openapi-typescript": "^7.4.3",
    "openapi-zod-client": "^1.15.0",
