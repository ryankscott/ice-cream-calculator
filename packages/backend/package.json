{
  "name": "@ice-cream-calculator/backend",
  "version": "1.0.0",
  "main": "./dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "type:check": "tsc --noEmit",
    "generate:schema": "tsx scripts/generate-openapi-schema.ts",
    "generate:types": "pnpm generate:schema && openapi-typescript openapi.json -o src/types/api-generated.ts"
  },
  "dependencies": {
    "@ice-cream-calculator/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.9.3",
    "@types/sqlite3": "^3.1.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
